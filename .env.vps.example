## Copy to .env on the VPS, then edit values.
COMPOSE_PROJECT_NAME=face_auth

## Public domain (must match FACEAUTH_DOMAIN in ../reverse-proxy/.env)
FACEAUTH_DOMAIN=face_auth.example.com

## Localhost ports the shared reverse proxy will hit
FACEAUTH_API_PORT=8084
FACEAUTH_ADMIN_PORT=8085

## Postgres
PG_USER=hik
PG_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING
PG_DB=hikpush

## MinIO (face images, event snapshots)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING
MINIO_BUCKET=hikpush
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_BASE=

## face_auth listener ports (internal — not exposed publicly in prod)
PUSH_PORT=7660
API_PORT=8080
ADMIN_PORT=80

## Frontend build-time API URL (leave empty in prod — same-origin via reverse proxy)
VITE_API_URL=

## Auth mode for legacy push-protocol devices (irrelevant in agent-mode setup)
NO_AUTH_MODE=true
DEVICE_DEFAULT_PASSWORD=

## Optional TLS/debug ports — empty in prod
DEBUG_PORT=
TLS_PORT=

## ---- Agent-related env (the agent itself runs on the LAN, not here) ----
## Set this on the agent box, not on the VPS:
##   CLOUD_URL=wss://face_auth.example.com
##   AGENT_ID=<from admin UI>
##   AGENT_TOKEN=<from admin UI>
EVENT_CALLBACK_IP=
PUBLIC_PUSH_HOST=
PUBLIC_PUSH_URL=

LOG_LEVEL=info
